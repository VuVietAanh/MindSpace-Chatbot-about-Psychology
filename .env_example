# ============================================================
# .env — Cấu hình cho Docker
# Copy file này thành .env và điền giá trị thật
# KHÔNG commit file .env lên Git!
# ============================================================

# ── LLM ─────────────────────────────────────────────────────
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512

# ── Database ─────────────────────────────────────────────────
# Local (SQLite) — dùng khi chạy python app.py trực tiếp
# DATABASE_URL=sqlite:///chatbot.db

# Docker (PostgreSQL) — dùng khi chạy docker compose
DATABASE_URL=

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Qdrant ───────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=mindspace_kb

# ── Pipeline ─────────────────────────────────────────────────
EMA_ALPHA=0.3
CRISIS_WATCH_TURNS=2
CRISIS_ALERT_TURNS=4
CRISIS_CRITICAL_TURNS=6
RETRIEVAL_TOP_K=3
RETRIEVAL_SCORE_THRESHOLD=0.3
RECENT_MSG_LIMIT=6

# ── Chunking ─────────────────────────────────────────────────
CHUNK_SIZE=256
CHUNK_OVERLAP=30
WINDOW_SIZE=1


# ----------------------------------------------------------------------
JWT_SECRET=
JWT_EXPIRE_MINUTES=10080